generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Setting {
  id    String @id @default("1")
  key   String @unique
  value String
}

model Centre {
  id                String    @id @default(cuid())
  name              String
   email             String    @unique
   password          String
   contactPhone      String?
  contactWhatsapp   String?
  logoUrl           String?
  subscriptionStatus String    @default("none") // none, trial_1min, trial_24h, trial_7d, active, expired, unlimited
  subscriptionPack   String    @default("")     // "1month", "1year", "unlimited"
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  isActive           Boolean   @default(true)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  users             User[]
  services          Service[]
  teachers          Teacher[]
  classrooms        Classroom[]
  students          Student[]
  promotions        Promotion[]
  packDiscounts     PackDiscount[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  nameFr      String
  description String?
  icon        String?
  order       Int      @default(0)
  centreId    String
  centre      Centre   @relation(fields: [centreId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  createdAt   DateTime @default(now())
}

model Subject {
  id         String    @id @default(cuid())
  name       String
  nameAr     String
  nameFr     String
  serviceId  String
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  levels     Level[]
  teachers   TeacherSubject[]
  schedules  Schedule[]
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
}

model Level {
  id        String  @id @default(cuid())
  name      String
  nameAr    String
  nameFr    String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  order          Int             @default(0)
  students       Student[]
  studentLevels  StudentLevel[]  @relation("StudentLevelLevel")
  schedules      Schedule[]
}

model Teacher {
  id            String           @id @default(cuid())
  fullName      String
  phone         String?
  email         String?
  address       String?
  salary        Float            @default(0)
  percentage    Float            @default(0)
  notes         String?
  status        String           @default("active")
  centreId      String
  centre        Centre           @relation(fields: [centreId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subjects       TeacherSubject[]
  schedules      Schedule[]
  payments       TeacherPayment[]
  students       Student[]
  studentLevels  StudentLevel[]  @relation("StudentLevelTeacher")
}

model TeacherSubject {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  levelIds  String  @default("")
}

model Classroom {
  id        String    @id @default(cuid())
  name      String
  nameAr    String
  capacity  Int       @default(20)
  centreId  String
  centre    Centre    @relation(fields: [centreId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  schedules Schedule[]
}

model Student {
  id            String   @id @default(cuid())
  fullName      String
  phone         String?
  email         String?
  address       String?
  levelId       String?
  level         Level?   @relation(fields: [levelId], references: [id])
  teacherId     String?
  teacher       Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  parentName    String?
  parentPhone   String?
  monthlyFee     Float    @default(0)
  packMonths     Int      @default(1)
  status        String   @default("active")
  centreId      String
  centre        Centre   @relation(fields: [centreId], references: [id], onDelete: Cascade)
  enrollmentDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  payments      Payment[]
  enrollments   StudentLevel[]
}

model Promotion {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  nameFr      String
  type        String   @default("badge")
  value       Float    @default(0)
  color       String   @default("#6366f1")
  icon        String   @default("Tag")
  active      Boolean  @default(true)
  centreId    String
  centre      Centre   @relation(fields: [centreId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payments    Payment[]
}

model PackDiscount {
  id              String    @id @default(cuid())
  name            String
  nameAr          String
  nameFr          String
  months          Int
  discountPercent Float     @default(0)
  active          Boolean   @default(true)
  centreId        String
  centre          Centre    @relation(fields: [centreId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
}

model Payment {
  id               String        @id @default(cuid())
  studentId        String
  student          Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount           Float
  paidAmount       Float         @default(0)
  remainingAmount  Float
  month            String
  year             Int
  paymentDate      DateTime?
  discount         Float         @default(0)
  discountReason   String?
  packMonths       Int           @default(1)
  method           String?
  notes            String?
  status           String        @default("pending")
  promotionId      String?
  promotion        Promotion?    @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  packDiscountId   String?
  packDiscount     PackDiscount? @relation(fields: [packDiscountId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TeacherPayment {
  id             String   @id @default(cuid())
  teacherId      String
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  amount         Float
  month          String
  year           Int
  paymentDate    DateTime?
  notes          String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  fullName    String
  role        String    @default("ADMIN") // SUPER_ADMIN or ADMIN
  status      String    @default("active")
  accessPages String    @default("") // comma-separated: dashboard,students,teachers,...
  centreId    String?
  centre      Centre?   @relation(fields: [centreId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    Session[]
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@map("sessions")
}

model StudentLevel {
  id         String    @id @default(cuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  levelId    String
  level      Level     @relation("StudentLevelLevel", fields: [levelId], references: [id])
  teacherId  String?
  teacher    Teacher?  @relation("StudentLevelTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  monthlyFee Float     @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Schedule {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])
  levelId     String?
  level       Level?   @relation(fields: [levelId], references: [id])
  dayOfWeek   String
  startTime   String
  endTime     String
  group       String?
  sessionType String   @default("fixed")
  isRecurring Boolean  @default(false)
  trialDate   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
